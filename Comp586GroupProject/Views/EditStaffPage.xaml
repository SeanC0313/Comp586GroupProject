<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Comp586GroupProject.Views.EditStaffPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Edit Staff">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Entry x:Name="FirstNameEntry" Placeholder="First name" />
            <Entry x:Name="LastNameEntry" Placeholder="Last name" />
            <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" />
            <Entry x:Name="SpecialtyEntry" Placeholder="Specialty" />
            <Picker x:Name="RolePicker" Title="Select role" />

            <HorizontalStackLayout Spacing="12">
                <Button Text="Save" Clicked="OnSaveClicked" />
                <Button Text="Cancel" Clicked="OnCancelClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>