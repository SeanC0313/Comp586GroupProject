<ContentPage
    x:Class="Comp586GroupProject.Views.NewBillingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="New Billing">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Entry x:Name="PatientIdEntry" Placeholder="Patient ID" Keyboard="Numeric" />
            <Entry x:Name="AppointmentIdEntry" Placeholder="Appointment ID" Keyboard="Numeric" />
            <Entry x:Name="AmountEntry" Placeholder="Amount" Keyboard="Numeric" />
            <Entry x:Name="InsuranceCoveredEntry" Placeholder="Insurance Covered" />
            <Picker x:Name="PaymentStatusPicker" Title="Payment Status" />

            <HorizontalStackLayout Spacing="12">
                <Button Text="Save" Clicked="OnSaveClicked" />
                <Button Text="Cancel" Clicked="OnCancelClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>