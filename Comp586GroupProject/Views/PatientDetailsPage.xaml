<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Comp586GroupProject.Views.PatientDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Patient Details">

    <VerticalStackLayout Padding="20" Spacing="10">
        <Label x:Name="NameLabel" FontSize="22" FontAttributes="Bold"/>
        <Label x:Name="DobLabel"/>
        <Label x:Name="EmailLabel"/>
        <Label x:Name="PhoneLabel"/>

        <Button Text="Schedule Appointment (stub)" IsEnabled="False"/>
        <Button Text="Create Invoice (stub)" IsEnabled="False"/>
    </VerticalStackLayout>
</ContentPage>