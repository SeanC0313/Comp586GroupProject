<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Comp586GroupProject.Views.PatientDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Patient Details">

	<VerticalStackLayout Padding="20" Spacing="12">
		<Label x:Name="NameLabel" FontSize="24" FontAttributes="Bold" />
		<Label x:Name="DobLabel" FontSize="16" />
		<Label x:Name="GenderLabel" FontSize="16" />
		<Label x:Name="PhoneLabel" FontSize="16" />
        <Label x:Name="EmailLabel" FontSize="16" />
        <Label x:Name="AddressLabel" FontSize="16" />
        <Label x:Name="InsuranceIdLabel" FontSize="16" />
        <Label x:Name="MedicalHistoryLabel" FontSize="16" />
        <Button Text="Medical Records" Clicked="OnMedicalRecordsClicked" />
        <Button Text="Prescriptions" Clicked="OnPrescriptionsClicked" />
        <Button Text="Labs" Clicked="OnLabsClicked" />
        <Button Text="Billing" Clicked="OnBillingClicked" />
    </VerticalStackLayout>
</ContentPage>