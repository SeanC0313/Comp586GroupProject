<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Comp586GroupProject.Views.EditAppointmentPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Edit Appointment">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Picker x:Name="PatientPicker" Title="Select patient" />
            <Picker x:Name="StaffPicker" Title="Select staff member" />
            <DatePicker x:Name="AppointmentDatePicker" />
            <TimePicker x:Name="AppointmentTimePicker" />
            <Picker x:Name="StatusPicker" Title="Select status" />
            <Editor x:Name="NotesEditor" Placeholder="Notes" AutoSize="TextChanges" />

            <HorizontalStackLayout Spacing="12">
                <Button Text="Save" Clicked="OnSaveClicked" />
                <Button Text="Cancel" Clicked="OnCancelClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>