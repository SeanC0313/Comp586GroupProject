<ContentPage
    x:Class="Comp586GroupProject.Views.NewSupplierPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="New Supplier">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Entry x:Name="NameEntry" Placeholder="Supplier Name" />
            <Entry x:Name="ContactNameEntry" Placeholder="Contact Name" />
            <Entry x:Name="PhoneEntry" Placeholder="Phone" Keyboard="Telephone" />
            <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" />
            <Editor x:Name="AddressEditor" Placeholder="Address" AutoSize="TextChanges" />

            <HorizontalStackLayout Spacing="12">
                <Button Text="Save" Clicked="OnSaveClicked" />
                <Button Text="Cancel" Clicked="OnCancelClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>