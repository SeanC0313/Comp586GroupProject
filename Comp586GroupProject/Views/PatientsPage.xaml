<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Comp586GroupProject.Views.PatientsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Patients">

	<Grid Padding="20" RowDefinitions="Auto,Auto,*" RowSpacing="12">
		<HorizontalStackLayout Grid.Row="0" Spacing="12">
			<SearchBar Placeholder="Search patients"
                       TextChanged="OnSearchChanged"
                       HorizontalOptions="FillAndExpand" />
			<Button Text="New Patient"
                    Clicked="OnNewPatient" />
		</HorizontalStackLayout>

		<Label x:Name="EmptyStateLabel"
               Grid.Row="1"
               Text="No patients found."
               IsVisible="False"
               FontSize="16" />

		<CollectionView x:Name="PatientsList"
                        Grid.Row="2"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Frame Margin="0,4" Padding="12">
						<VerticalStackLayout Spacing="4">
							<Label FontAttributes="Bold" FontSize="18">
								<Label.FormattedText>
									<FormattedString>
										<Span Text="{Binding FirstName}" />
										<Span Text=" " />
										<Span Text="{Binding LastName}" />
									</FormattedString>
								</Label.FormattedText>
							</Label>

							<Label Text="{Binding DOB, StringFormat='DOB: {0:MMMM d, yyyy}'}" />
							<Label Text="{Binding Gender, StringFormat='Gender: {0}'}" />
							<Label Text="{Binding Phone, StringFormat='Phone: {0}'}" />
							<Label Text="{Binding Address, StringFormat='Address: {0}'}" />

                            <HorizontalStackLayout Spacing="10">
                                <Button Text="Edit" Clicked="OnEditPatientClicked" />
                                <Button Text="Delete" Clicked="OnDeletePatientClicked" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
					</Frame>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
	</Grid>
</ContentPage>