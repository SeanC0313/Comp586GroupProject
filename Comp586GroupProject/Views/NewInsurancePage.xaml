<ContentPage
    x:Class="Comp586GroupProject.Views.NewInsurancePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="New Insurance">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Entry x:Name="ProviderNameEntry" Placeholder="Provider Name" />
            <Entry x:Name="PhoneEntry" Placeholder="Phone" Keyboard="Telephone" />
            <Editor x:Name="CoverageDetailsEditor" Placeholder="Coverage Details" AutoSize="TextChanges" />

            <HorizontalStackLayout Spacing="12">
                <Button Text="Save" Clicked="OnSaveClicked" />
                <Button Text="Cancel" Clicked="OnCancelClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>