<ContentPage
    x:Class="Comp586GroupProject.Views.BillingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Billing">

    <VerticalStackLayout Padding="20" Spacing="12">
        <CollectionView x:Name="BillingList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="0,4">
                        <VerticalStackLayout>
                            <Label Text="{Binding BillingId, StringFormat='Bill ID: {0}'}" FontAttributes="Bold" />
                            <Label Text="{Binding PatientId, StringFormat='Patient ID: {0}'}" />
                            <Label Text="{Binding AppointmentId, StringFormat='Appointment ID: {0}'}" />
                            <Label Text="{Binding Amount, StringFormat='Amount: {0:C}'}" />
                            <Label Text="{Binding InsuranceCovered, StringFormat='Insurance Covered: {0}'}" />
                            <Label Text="{Binding PaymentStatus, StringFormat='Status: {0}'}" />
                            <Button Text="Delete" Clicked="OnDeleteClicked" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>